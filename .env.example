# ─── Discord ────────────────────────────────────────────────────────────────
# Bot token from the Discord Developer Portal (Bot > Token)
DISCORD_TOKEN=
# Application/client ID and the target guild (server) ID
CLIENT_ID=
GUILD_ID=
# Channel where the bot posts match alerts, scheduled and custom messages
NOTIFY_CHANNEL_ID=

# ─── Optional scheduled daily message ────────────────────────────────────────
# Leave DAILY_MESSAGE empty to disable. Posted to NOTIFY_CHANNEL_ID.
DAILY_MESSAGE=
DAILY_MESSAGE_HOUR=11

# ─── Bot language ─────────────────────────────────────────────────────────────
# pt-br or en-us
BOT_LANG=pt-br

# ─── AI / text-to-speech (optional features) ─────────────────────────────────
GROQ_API_KEY=
ELEVEN_TOKEN=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# ─── Clip editor ──────────────────────────────────────────────────────────────
CLIP_EDITOR_BASE_URL=
CLIP_EDITOR_SECRET=
